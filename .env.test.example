NODE_ENV=test
LOG_LEVEL=warn
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent_passport_test
DATABASE_URL_POOLED=postgresql://postgres:postgres@localhost:5432/talent_passport_test
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/talent_passport_test
REDIS_URL=redis://localhost:6379
AUTH_PROVIDER=clerk
AUTH_ADMIN_EMAILS=
JWT_ACCESS_SECRET=test-access-secret
JWT_REFRESH_SECRET=test-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
STORAGE_PROVIDER=local
STORAGE_BUCKET=talent-passport-test
STORAGE_SIGNING_SECRET=test-storage-signing-secret
STORAGE_SIGNED_URL_TTL_SECONDS=900
STORAGE_MAX_FILE_SIZE_BYTES=10485760
STORAGE_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain,text/csv
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_ENABLED=false
CSRF_HEADER_NAME=x-csrf-token
CSRF_ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

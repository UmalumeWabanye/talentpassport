NODE_ENV=production
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@staging-db:5432/talent_passport_staging
DATABASE_URL_POOLED=postgresql://postgres:postgres@staging-db:5432/talent_passport_staging
DIRECT_URL=postgresql://postgres:postgres@staging-db:5432/talent_passport_staging
REDIS_URL=redis://staging-redis:6379
AUTH_PROVIDER=clerk
AUTH_ADMIN_EMAILS=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
STORAGE_PROVIDER=local
STORAGE_BUCKET=talent-passport-staging
STORAGE_SIGNING_SECRET=
STORAGE_SIGNED_URL_TTL_SECONDS=900
STORAGE_MAX_FILE_SIZE_BYTES=10485760
STORAGE_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain,text/csv
STORAGE_PUBLIC_BASE_URL=https://api-staging.talent-passport.example/v1
CORS_ALLOWED_ORIGINS=https://staging.talent-passport.example
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
CSRF_ENABLED=true
CSRF_HEADER_NAME=x-csrf-token
CSRF_ALLOWED_ORIGINS=https://staging.talent-passport.example
NEXT_PUBLIC_APP_URL=https://staging.talent-passport.example
NEXT_PUBLIC_API_URL=https://api-staging.talent-passport.example/v1

NODE_ENV=development
LOG_LEVEL=debug
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talent_passport_local
DATABASE_URL_POOLED=postgresql://postgres:postgres@localhost:5432/talent_passport_local
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/talent_passport_local
REDIS_URL=redis://localhost:6379
AUTH_PROVIDER=clerk
AUTH_ADMIN_EMAILS=admin@talentpassport.local
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
JWT_ACCESS_SECRET=local-access-secret
JWT_REFRESH_SECRET=local-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
STORAGE_PROVIDER=local
STORAGE_BUCKET=talent-passport-local
STORAGE_SIGNING_SECRET=local-storage-signing-secret
STORAGE_SIGNED_URL_TTL_SECONDS=900
STORAGE_MAX_FILE_SIZE_BYTES=10485760
STORAGE_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain,text/csv
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

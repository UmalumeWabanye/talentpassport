NODE_ENV=production
LOG_LEVEL=warn
DATABASE_URL=postgresql://postgres:postgres@prod-db:5432/talent_passport
DATABASE_URL_POOLED=postgresql://postgres:postgres@prod-db:5432/talent_passport
DIRECT_URL=postgresql://postgres:postgres@prod-db:5432/talent_passport
REDIS_URL=redis://prod-redis:6379
AUTH_PROVIDER=clerk
AUTH_ADMIN_EMAILS=
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
STORAGE_PROVIDER=local
STORAGE_BUCKET=talent-passport-production
STORAGE_SIGNING_SECRET=
STORAGE_SIGNED_URL_TTL_SECONDS=900
STORAGE_MAX_FILE_SIZE_BYTES=10485760
STORAGE_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,text/plain,text/csv
STORAGE_PUBLIC_BASE_URL=https://api.talent-passport.example/v1
NEXT_PUBLIC_APP_URL=https://talent-passport.example
NEXT_PUBLIC_API_URL=https://api.talent-passport.example/v1

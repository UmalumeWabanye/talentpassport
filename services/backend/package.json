{
  "name": "@talent-passport/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prisma:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://user:password@localhost:5432/talent_passport?schema=public} DATABASE_URL_POOLED=${DATABASE_URL_POOLED:-$DATABASE_URL} DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} prisma generate --config ../../database/prisma/prisma.config.mjs --schema ../../database/prisma/schema.prisma",
    "dev": "nest start --watch",
    "prebuild": "pnpm prisma:generate",
    "build": "nest build -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "pretypecheck": "pnpm prisma:generate",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretest": "pnpm prisma:generate",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.3",
    "@nestjs/core": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.3",
    "@nestjs/swagger": "^11.4.6",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@talent-passport/config": "workspace:*",
    "argon2": "^0.45.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@types/supertest": "^6.0.3",
    "prisma": "^7.9.0",
    "supertest": "^7.1.4",
    "typescript": "^5.7.3"
  }
}
